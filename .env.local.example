# ============================================================
#  HealthMe A.I – Umgebungsvariablen
#  Kopiere diese Datei nach `.env.local` und fülle die Werte aus.
#  In Vercel: Project Settings → Environment Variables.
# ============================================================

# --- Supabase ---------------------------------------------------
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://DEIN-PROJEKT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=dein-anon-key
# Service-Role-Key (NUR serverseitig, NIEMALS im Browser!)
SUPABASE_SERVICE_ROLE_KEY=dein-service-role-key

# --- Grok / xAI -------------------------------------------------
# https://console.x.ai  → API Keys
GROK_API_KEY=xai-...
GROK_MODEL=grok-3
# Vision-Modell für den Mahlzeiten-Scan (Foto-Analyse)
GROK_VISION_MODEL=grok-2-vision-1212

# --- ExerciseDB (RapidAPI) – animierte Übungs-GIFs für den Coach -----
# RapidAPI → "ExerciseDB" (by Justin) → Basic (Free) abonnieren → X-RapidAPI-Key kopieren
RAPIDAPI_KEY=

# --- Resend (E-Mail-Versand) ------------------------------------
# https://resend.com → API Keys
RESEND_API_KEY=re_...
# Verifizierte Absender-Adresse (Domain muss in Resend verifiziert sein)
EMAIL_FROM="HealthMe A.I <noreply@deine-domain.de>"

# --- Digistore24 Webhook ----------------------------------------
# Digistore24 → Einstellungen → IPN / Zahlungs-Benachrichtigung
# Die "Passphrase" / "SHA-Signatur-Passphrase" aus Digistore24 hier eintragen.
DIGISTORE_PASSPHRASE=deine-digistore-passphrase

# --- App ---------------------------------------------------------
# Öffentliche Basis-URL der App (für Login-Link in der E-Mail)
NEXT_PUBLIC_SITE_URL=https://deine-app.vercel.app
# Standard-Passwort für neue Käufer (beim ersten Login zu ändern)
DEFAULT_USER_PASSWORD=123456789
